{
  "title": "SORA.Earth API Monitoring",
  "uid": "sora-earth-api",
  "panels": [
    {"title":"Request Rate","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":0},"targets":[{"expr":"rate(http_requests_total[1m])","legendFormat":"{{method}} {{handler}}"}],"datasource":"Prometheus"},
    {"title":"Response Time p95","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":0},"targets":[{"expr":"histogram_quantile(0.95,rate(http_request_duration_seconds_bucket[5m]))","legendFormat":"p95"}],"datasource":"Prometheus"},
    {"title":"Active Requests","type":"stat","gridPos":{"h":4,"w":6,"x":0,"y":8},"targets":[{"expr":"http_requests_in_progress"}],"datasource":"Prometheus"},
    {"title":"Error Rate","type":"stat","gridPos":{"h":4,"w":6,"x":6,"y":8},"targets":[{"expr":"rate(http_requests_total{status=~\"5..\"}[5m])"}],"datasource":"Prometheus"},
    {"title":"Total Requests","type":"stat","gridPos":{"h":4,"w":6,"x":12,"y":8},"targets":[{"expr":"http_requests_total"}],"datasource":"Prometheus"},
    {"title":"Memory Usage","type":"stat","gridPos":{"h":4,"w":6,"x":18,"y":8},"targets":[{"expr":"process_resident_memory_bytes/1024/1024"}],"datasource":"Prometheus","fieldConfig":{"defaults":{"unit":"decmbytes"}}}
  ],
  "time": {"from":"now-1h","to":"now"},
  "refresh": "5s",
  "schemaVersion": 30
}
