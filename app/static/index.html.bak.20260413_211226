<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>SORA.Earth — ESG Platform</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/static/favicon.svg" type="image/svg+xml" />
  <style>
    :root {
      --bg: #0b1020;
      --panel: #151b30;
      --panel-2: #11172a;
      --line: #222a3d;
      --line-2: #2b3550;
      --text: #f5f7fb;
      --muted: #9aa4bd;
      --blue: #3c84ff;
      --green: #10b981;
      --amber: #f59e0b;
      --red: #ef4444;
      --cyan: #06b6d4;
      --purple: #8b5cf6;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; background: var(--bg); color: var(--text); font-family: Inter, system-ui, sans-serif; }
    body { min-height: 100vh; }

    header {
      padding: 16px 24px;
      background: #12182b;
      display: flex;
      justify-content: space-beeen;
      align-items: center;
      gap: 16px;
      border-bottom: 1px solid var(--line);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .logo { font-weight: 700; letter-spacing: 0.04em; }
    .tag { font-size: 12px; color: var(--muted); margin-top: 4px; }

    .nav { display: flex; gap: 8px; flex-wrap: wrap; }
    .nav-item {
      cursor: pointer;
      background: #1b2238;
      border-radius: 999px;
      border: 1px solid var(--line);
      padding: 8px 14px;
      font-size: 12px;
      color: var(--text);
    }
    .nav-item.active {
      background: var(--blue);
      border-color: var(--blue);
      color: #fff;
    }

    main {
      max-width: 1200px;
      margin: 24px auto 40px;
      padding: 0 16px;
    }

    .page { display: none; }
    .page.active { display: block; }

    .grid-2 {
      display: grid;
      grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
      gap: 24px;
    }

    .cards-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .cards-4 {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .card {
      background: var(--panel);
      border-radius: 12px;
      padding: 16px 18px;
      border: 1px solid var(--line);
      box-shadow: 0 4px 18px rgba(0,0,0,0.18);
    }

    h1 { margin: 0 0 8px; font-size: 26px; }
    h2 { margin: 0 0 10px; font-size: 18px; }
    h3 { margin: 16px 0 8px; font-size: 15px; }

    p { margin: 0 0 10px; }
    .small { font-size: 12px; color: var(--muted); }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }

    label {
      display: block;
      margin: 10px 0 6px;
      font-size: 13px;
      color: #d9e1f2;
    }

    input, select, textarea {
      width: 100%;
      padding: 9px 10px;
      border-radius: 8px;
      border: 1px solid var(--line-2);
      background: #0f1424;
      color: var(--text);
      font-size: 13px;
    }

    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: var(--blue);
    }

    button {
      cursor: pointer;
      padding: 9px 14px;
      border-radius: 8px;
      border: none;
      background: var(--blue);
      color: #fff;
      font-weight: 600;
      font-size: 13px;
    }

    button.secondary {
      background: #1b2238;
      border: 1px solid var(--line);
    }

    button:disabled {
      opacity: 0.65;
      cursor: default;
    }

    .row { display: flex; gap: 10px; }
    .row > div { flex: 1; }

    .pill {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11px;
      background: #1e253a;
      margin-right: 6px;
    }
    .pill.low { background: rgba(16,185,129,0.18); color: #7af0bf; }
    .pill.medium { background: rgba(245,158,11,0.18); color: #f7c66a; }
    .pill.high { background: rgba(239,68,68,0.18); color: #ff9d9d; }

    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 8px;
    }

    .metric, .stat-card {
      background: var(--panel-2);
      border-radius: 10px;
      padding: 10px 12px;
      border: 1px solid var(--line);
    }

    .metric-label, .label {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: .04em;
    }

    .metric-value, .value {
      font-size: 16px;
      font-weight: 700;
    }

    ul { padding-left: 18px; }
    li { margin-bottom: 6px; }

    pre {
      margin: 8px 0 0;
      padding: 10px;
      border-radius: 8px;
      background: #0f1424;
      overflow: auto;
      border: 1px solid var(--line);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    th, td {
      text-align: left;
      padding: 10px 8px;
      border-bottom: 1px solid var(--line);
    }

    .toolbar {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .section-gap { margin-top: 16px; }
    .muted { color: var(--muted); }

    #map {
      height: 320px;
      border-radius: 10px;
      overflow: hidden;
      background: #0f1424;
      border: 1px solid var(--line);
    }

    #regionCards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .region-card {
      background: var(--panel-2);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 10px 12px;
    }

    .hero {
      margin-bottom: 18px;
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
      gap: 16px;
    }

    .hero .card:first-child {
      background: linear-gradient(135deg, rgba(60,132,255,0.12), rgba(6,182,212,0.10), rgba(21,27,48,1));
    }

    canvas {
      width: 100% !important;
      max-width: 100%;
      min-height: 220px;
    }

    @media (max-width: 900px) {
      header { flex-direction: column; align-items: flex-start; }
      .grid-2, .hero, .cards-2, .cards-4 { grid-template-columns: minmax(0, 1fr); }
      .row { flex-direction: column; }
      .metrics-grid { grid-template-columns: minmax(0, 1fr); }
      #regionCards { grid-template-columns: minmax(0, 1fr); }
    }
  </style>
</head>
<body>
  <header>
    <div>
      <div class="logo">SORA.Earth ESG Platform</div>
      <div class="tag">AI-assisted ESG evaluation, explainability and country analytics</div>
    </div>
    <nav class="nav">
      <button class="nav-item active" onclick="showPage('evaluate', this)">Evaluate</button>
      <button class="nav-item" onclick="showPage('analytics', this)">Analytics</button>
      <button class="nav-item" onclick="showPage('countries', this)">Countries</button>
      <button class="nav-item" onclick="showPage('history', this)">History</button>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="card">
        <h1>Operational ESG workspace</h1>
        <p class="small">Evaluate projects, inspect model signals, compare country benchmarks and review historical decisions from one interface.</p>
      </div>
      <div class="card">
        <div class="label">Endpoints</div>
        <div class="small mono">/evaluate · /what-if · /predict/explain · /analytics/*</div>
      </div>
    </section>

    <section id="page-evaluate" class="page active">
      <div class="grid-2">
        <div>
          <div class="card">
            <h2>Evaluate a project</h2>
            <p class="small">Fill in the project parameters and send them to <span class="mono">POST /evaluate</span>.</p>

            <form id="eval-form">
              <label>Project name</label>
              <input id="e-name" name="name" placeholder="Solar Farm Alpha" required />

              <div class="row">
                <div>
                  <label>Budget (USD)</label>
                  <input id="e-budget" name="budget" type="number" step="1" min="0" value="100000" required />
                </div>
                <div>
                  <label>Duration (ths)</label>
                  <input id="e-duration" name="duration_months" type="number" step="1" min="1" value="24" required />
                </div>
              </div>

              <div class="row">
                <div>
                  <label>CO₂ reduction (tons/year)</label>
                  <input id="e-co2" name="co2_reduction" type="number" step="1" min="0" value="60" required />
                </div>
                <div>
                  <label>Social impact (0–10)</label>
                  <input id="e-social" name="social_impact" type="number" step="1" min="0" max="10" value="8" required />
                </div>
              </div>

              <label>Region / Country</label>
              <input id="e-country" name="region" placeholder="Germany" />

              <div class="toolbar">
                <button type="submit" id="eval-btn">Evaluate ESG</button>
                <button type="button" class="secondary" onclick="whatIf()">What-if</button>
                <button typetton" class="secondary" onclick="predictStacking()">Stacking</button>
                <span id="eval-status" class="small"></span>
              </div>
            </form>
          </div>

          <div class="card section-gap">
            <h2>Result</h2>
            <div id="result-empty" class="small">No evaluation yet. Submit the form to see ESG scores.</div>
            <div id="result-view" style="display:none;">
              <div style="margin-bottom: 10px;">
                <span class="pill" id="risk-pill">Risk: –</span>
                <span class="pill" id="prob-pill">Success: <span id="prob-val">–</span>%</span>
              </div>

              <div class="cards-2">
                <div class="metric">
                  <div class="metric-label">Total ESG score</div>
                  <div class="metric-value" id="score-total">–</div>
                </div>
                <div class="metric">
                  <div class="metric-label">Environment / Social / Economic</div>
            <div class="metric-value" id="score-breakdown">–</div>
                </div>
              </div>

              <h3>Recommendations</h3>
              <ul id="recs-list" class="small"></ul>

              <h3>Raw response</h3>
              <pre class="mono" id="raw-json"></pre>
            </div>
          </div>
        </div>

        <aside>
          <div class="card">
            <h2>Live metrics</h2>
            <p class="small">Values from <span class="mono">GET /metrics</span>, updated every 10 seconds.</p>
            <div class="metrics-grid">
              <div class="metric">
                <div class="metric-label">HTTP requests total</div>
                <div class="metric-value" id="m-requests">–</div>
              </div>
              <div class="metric">
                <div class="metric-label">Errors total</div>
                <div class="metric-value" id="m-errors">–</div>
              </div>
              <div class="metric">
                <div class="metric-label">Ups)</div>
                <div class="metric-value" id="m-uptime">–</div>
              </div>
              <div class="metric">
                <div class="metric-label">Avg req duration (ms)</div>
                <div class="metric-value" id="m-rt">–</div>
              </div>
            </div>
            <div class="small" style="margin-top: 8px;" id="metrics-status"></div>
          </div>

          <div class="card section-gap">
            <h2>Batch evaluation</h2>
            <p class="small">Use <span class="mono">POST /batch/evaluate</span> with an array of projects.</p>
            <pre class="mono small">curl -X POST http://localhost:8000/batch/evaluate \
-H "Content-Type: application/json" \
-d '{"projects":[{"name":"Solar A","budget":100000,"co2_reduction":60,"social_impact":8,"duration_months":24,"region":"Germany"}]}'</pre>
          </div>
        </aside>
      </div>
    </section>

    <section id="page-analytics" class="page">
      <div class="cards-2">
        <div class="card">       <h2>Portfolio overview</h2>
          <div id="dashStats" class="cards-4"></div>
        </div>
        <div class="card">
          <h2>Top projects</h2>
          <div id="topProjects" class="small muted">No data yet.</div>
        </div>
      </div>

      <div class="cards-2 section-gap">
        <div class="card">
          <h2>Distribution</h2>
          <canvas id="distChart"></canvas>
        </div>
        <div class="card">
          <h2>Feature importance</h2>
          <canvas id="featChart"></canvas>
        </div>
      </div>

      <div class="cards-2 section-gap">
        <div class="card">
          <h2>Model stacking</h2>
          <p class="small">Run ensemble prediction on the current project fields from the Evaluate page.</p>
          <button onclick="predictStacking()">Run stacking</button>
          <div id="stackResult" style="display:none; margin-top:12px;">
            <div id="stackTitle" style="font-weight:700; margin-bottom:8px;"></div>
            <div>Ensemble probability: <span id="stackProb">–</span></div>
            <div id="stackModels" class="metrics-grid" style="margin-top:10px;"></div>
            <canvas id="stackChart" style="margin-top:12px;"></canvas>
          </div>
        </div>

        <div class="card">
          <h2>SHAP explainability</h2>
          <p class="small">Feature contribution chart for the current project.</p>
          <canvas id="shapChart"></canvas>
        </div>
      </div>
    </section>

    <section id="page-countries" class="page">
      <div class="cards-2">
        <div class="card">
          <h2>Country benchmark</h2>
          <label>Select country</label>
          <select id="countrySelect"></select>
          <pre id="countryBenchmark" class="mono small"></pre>
        </div>
        <div class="card">
          <h2>Country ranking</h2>
          <table>
            <thead>
              <tr><th>#</th><th>Country</th><th>Score</th></tr>
            </thead>
            <tbody id="countryRanking"></tbody>
          </tle>
        </div>
      </div>

      <div class="card section-gap">
        <h2>Project geography</h2>
        <div id="map"></div>
        <div id="regionCards"></div>
      </div>
    </section>

    <section id="page-history" class="page">
      <div class="card">
        <h2>Evaluation history</h2>
        <table>
          <thead>
            <tr><th>Project</th><th>ESG</th><th>Success</th><th>Risk</th></tr>
          </thead>
          <tbody id="evalHistBody"></tbody>
        </table>

        <div class="toolbar" style="justify-content:flex-end;">
          <button onclick="window.location.href='/export/csv'">Export CSV</button>
          <button class="secondary" onclick="if(confirm('Clear all history?')) fetch('/history',{method:'DELETE'}).then(()=>loadEvalHistory())">Clear history</button>
        </div>
      </div>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="/static/app.js"></script>

  <script>
    async function evaluateProject(event) {
      event.preventDefault();
      const form = event.target;
      const btn = document.getElementById("eval-btn");
      const statusEl = document.getElementById("eval-status");
      const payload = {
        name: form.name.value || "Untitled project",
        budget: Number(form.budget.value),
        co2_reduction: Number(form.co2_reduction.value),
        social_impact: Number(form.social_impact.value),
        duration_months: Number(form.duration_months.value),
        region: form.region.value || null
      };

      btn.disabled = true;
      statusEl.textContent = "Sending request…";

      try {
        const res = await fetch("/evaluate", {
          method: "POST",
          headers: {"Content-Type": "application/json"},
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (!res.) throw new Error(data.detail || "Request failed");
        renderResult(data);
        statusEl.textContent = "OK";
      } catch (err) {
        statusEl.textContent = "Error: " + err.message;
      } finally {
        btn.disabled = false;
      }
    }

    function renderResult(data) {
      document.getElementById("result-empty").style.display = "none";
      document.getElementById("result-view").style.display = "block";

      document.getElementById("score-total").textContent =
        data.total_score !== undefined ? data.total_score.toFixed(2) : "–";

      if (data.environment_score !== undefined && data.social_score !== undefined && data.economic_score !== undefined) {
        document.getElementById("score-breakdown").textContent =
          `${data.environment_score.toFixed(1)} / ${data.social_score.toFixed(1)} / ${data.economic_score.toFixed(1)}`;
      } else {
        document.getElementById("score-breakdown").textContent = "–";
      }

      const prob = data.success_probability !== fined ? (data.success_probability * 100).toFixed(1) : null;
      document.getElementById("prob-val").textContent = prob !== null ? prob : "–";

      const risk = (data.risk_level || "").toLowerCase();
      const pill = document.getElementById("risk-pill");
      pill.textContent = data.risk_level ? `Risk: ${data.risk_level}` : "Risk: –";
      pill.classList.remove("low", "medium", "high");
      if (risk === "low") pill.classList.add("low");
      else if (risk === "medium") pill.classList.add("medium");
      else if (risk === "high") pill.classList.add("high");

      const recsUl = document.getElementById("recs-list");
      recsUl.innerHTML = "";
      if (Array.isArray(data.recommendations)) {
        data.recommendations.forEach((r) => {
          const li = document.createElement("li");
          li.textContent = r;
          recsUl.appendChild(li);
        });
      } else if (typeof data.recommendations === "string") {
        const li = document.createElement("li");
        li.textContent ta.recommendations;
        recsUl.appendChild(li);
      }

      document.getElementById("raw-json").textContent = JSON.stringify(data, null, 2);
    }

    async function fetchMetrics() {
      const statusEl = document.getElementById("metrics-status");
      try {
        const res = await fetch("/metrics");
        if (!res.ok) throw new Error("HTTP " + res.status);
        const data = await res.json();
        const counters = data.counters || {};
        document.getElementById("m-requests").textContent = counters.http_requests_total ?? "0";
        const errors = (Number(counters.http_400 || 0) + Number(counters.http_500 || 0)) || (counters.errors_total ?? 0);
        document.getElementById("m-errors").textContent = errors;
        document.getElementById("m-uptime").textContent = data.uptime_seconds ?? "–";
        document.getElementById("m-rt").textContent = data.request_duration_avg_ms ?? "–";
        statusEl.textContent = "";
      } catch (err) {
        statusEl.textContent = "Failed tad metrics: " + err.message;
      }
    }

    window.loadCountryRanking = function () {
      fetch("/analytics/country-ranking")
        .then(r => r.json())
        .then(j => {
          const tbody = document.getElementById("countryRanking");
          if (!tbody) return;
          const items = Array.isArray(j) ? j : (j.items || []);
          tbody.innerHTML = items.slice(0, 20).map((c, idx) => {
            const country = c.country || c.name || c.country_name || "—";
            const score = c.score ?? c.esg_score ?? c.total_score ?? "—";
            return `<tr><td>${idx + 1}</td><td>${country}</td><td>${score}</td></tr>`;
          }).join("");
        })
        .catch(err => {
          const tbody = document.getElementById("countryRanking");
          if (tbody) tbody.innerHTML = `<tr><td colspan="3">Failed to load: ${err.message}</td></tr>`;
        });
    };

    window.loadCountryBenchmark = function () {
      const select = document.getElementById("countrySelect");
      if (!selec !select.value) return;
      fetch("/analytics/country-benchmark/" + encodeURIComponent(select.value))
        .then(r => r.json())
        .then(j => {
          document.getElementById("countryBenchmark").textContent = JSON.stringify(j, null, 2);
        })
        .catch(err => {
          document.getElementById("countryBenchmark").textContent = "Failed to load: " + err.message;
        });
    };

    window.initCountries = function () {
      fetch("/countries")
        .then(r => r.json())
        .then(list => {
          const select = document.getElementById("countrySelect");
          if (!select) return;
          const items = Array.isArray(list) ? list : (list.countries || []);
          select.innerHTML = items.map(c => `<option value="${c}">${c}</option>`).join("");
          select.onchange = loadCountryBenchmark;
          if (items.length) loadCountryBenchmark();
          loadCountryRanking();
          if (typeof initMap === "function") setTimeout(initMap, 50);
        })
        .catch(err => {
          document.getElementById("countryBenchmark").textContent = "Failed to load countries: " + err.message;
        });
    };

    if (window.showPage) {
      const originalShowPage = window.showPage;
      window.showPage = function(id, el) {
        originalShowPage(id, el);
        if (id === "countries") initCountries();
        if (id === "history") loadEvalHistory();
      };
    }

    document.getElementById("eval-form").addEventListener("submit", evaluateProject);
    fetchMetrics();
    setInterval(fetchMetrics, 10000);
  </script>
</body>
</html>
